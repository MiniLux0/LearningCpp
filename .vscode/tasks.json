{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "make: compilar todo",
            "type": "shell",
            "command": "make",
            "args": ["all"],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "Compila todos los .cpp de la carpeta actual"
        },
        {
            "label": "make: run archivo actual",
            "type": "shell",
            "command": "make",
            "args": ["run-${fileBasenameNoExtension}"],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "Compila y ejecuta el archivo activo"
        },
        {
            "label": "make: run con ASan",
            "type": "shell",
            "command": "make",
            "args": ["run-asan-${fileBasenameNoExtension}"],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": ["$gcc"],
            "detail": "Compila y ejecuta el archivo activo con AddressSanitizer"
        },
        {
            "label": "make: clean",
            "type": "shell",
            "command": "make",
            "args": ["clean"],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [],
            "detail": "Elimina build/ y buildasan/ de la carpeta actual"
        }
    ]
}